; Kopiere diese Datei nach .env (Project-Root) und passe die Werte an.
; .env wird per /.gitignore nicht commited.
;
; Production (Ploi): Site → General → "Edit environment" — Ploi schreibt die
; Datei automatisch nach Project-Root mit korrekten Permissions.
;
; ADMIN_PASSWORD_HASH erzeugen (nutzt PASSWORD_DEFAULT — derzeit bcrypt
; cost 12, in zukuenftigen PHP-Versionen ggf. Argon2id):
;   php -r "echo password_hash('dein-passwort', PASSWORD_DEFAULT) . PHP_EOL;"

ADMIN_USER          = "admin"
ADMIN_PASSWORD_HASH = "$2y$12$REPLACE_THIS_WITH_YOUR_OWN_BCRYPT_HASH......................"
